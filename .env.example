# Postgres connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=student_warehouse
POSTGRES_USER=warehouse
POSTGRES_PASSWORD=warehouse_dev_only

# Inside docker-compose, Postgres is reachable as `postgres`:
# POSTGRES_HOST=postgres

# Path to the seed CSVs (bundled in data/sample/)
SEED_DIR=data/sample

# Metabase admin (optional, only used by metabase_setup.py)
METABASE_URL=http://localhost:3000
METABASE_ADMIN_EMAIL=admin@example.com
METABASE_ADMIN_PASSWORD=admin_dev_only

# Logging
LOG_LEVEL=INFO
